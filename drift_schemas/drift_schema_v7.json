    {
      "name": "clients",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"clients\" (\"id\" INTEGER NOT NULL PRIMARY KEY AUTOINCREMENT, \"name\" TEXT NOT NULL, \"contact_name\" TEXT NULL, \"email\" TEXT NULL, \"phone\" TEXT NULL, \"address\" TEXT NULL, \"abn\" TEXT NULL, \"default_rate\" REAL NOT NULL, \"archived_at\" INTEGER NULL);"
        }
      ]
    },
    {
      "name": "projects",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"projects\" (\"id\" INTEGER NOT NULL PRIMARY KEY AUTOINCREMENT, \"client_id\" INTEGER NOT NULL REFERENCES clients (id), \"code\" TEXT NOT NULL UNIQUE, \"title\" TEXT NOT NULL, \"rate\" REAL NULL, \"status\" TEXT NOT NULL DEFAULT 'active', \"created_at\" INTEGER NOT NULL DEFAULT (CAST(strftime('%s', CURRENT_TIMESTAMP) AS INTEGER)));"
        }
      ]
    },
