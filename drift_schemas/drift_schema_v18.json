  "fixed_sql": [
    {
      "name": "clients",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"clients\" (\"id\" TEXT NOT NULL, \"name\" TEXT NOT NULL, \"contact_name\" TEXT NULL, \"email\" TEXT NULL, \"phone\" TEXT NULL, \"address\" TEXT NULL, \"abn\" TEXT NULL, \"default_rate\" REAL NOT NULL, \"archived_at\" INTEGER NULL, \"created_at\" INTEGER NULL, \"updated_at\" INTEGER NULL, \"deleted_at\" INTEGER NULL, \"org_id\" TEXT NULL, PRIMARY KEY (\"id\"));"
        }
      ]
    },
    {
      "name": "projects",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"projects\" (\"id\" TEXT NOT NULL, \"client_id\" TEXT NOT NULL REFERENCES clients (id), \"code\" TEXT NOT NULL UNIQUE, \"title\" TEXT NOT NULL, \"rate\" REAL NULL, \"status\" TEXT NOT NULL DEFAULT 'active', \"archived_at\" INTEGER NULL, \"created_at\" INTEGER NOT NULL DEFAULT (CAST(strftime('%s', CURRENT_TIMESTAMP) AS INTEGER)), \"updated_at\" INTEGER NULL, \"deleted_at\" INTEGER NULL, \"org_id\" TEXT NULL, PRIMARY KEY (\"id\"));"
        }
      ]
    },
    {
      "name": "tasks",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"tasks\" (\"id\" TEXT NOT NULL, \"project_id\" TEXT NOT NULL REFERENCES projects (id), \"title\" TEXT NOT NULL, \"rate\" REAL NULL, \"status\" TEXT NOT NULL DEFAULT 'active', \"created_at\" INTEGER NOT NULL DEFAULT (CAST(strftime('%s', CURRENT_TIMESTAMP) AS INTEGER)), \"updated_at\" INTEGER NULL, \"deleted_at\" INTEGER NULL, \"org_id\" TEXT NULL, PRIMARY KEY (\"id\"));"
        }
      ]
    },
    {
      "name": "time_entries",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"time_entries\" (\"id\" TEXT NOT NULL, \"project_id\" TEXT NOT NULL REFERENCES projects (id), \"task_id\" TEXT NULL REFERENCES tasks (id), \"description\" TEXT NULL, \"started_at\" INTEGER NOT NULL, \"ended_at\" INTEGER NOT NULL, \"seconds\" INTEGER NOT NULL, \"created_at\" INTEGER NULL, \"updated_at\" INTEGER NULL, \"deleted_at\" INTEGER NULL, \"org_id\" TEXT NULL, PRIMARY KEY (\"id\"));"
        }
      ]
    },
    {
      "name": "templates",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"templates\" (\"id\" TEXT NOT NULL, \"name\" TEXT NOT NULL, \"color_background\" INTEGER NOT NULL, \"color_surface\" INTEGER NOT NULL, \"color_primary\" INTEGER NOT NULL, \"color_text\" INTEGER NOT NULL, \"color_accent\" INTEGER NOT NULL, \"font_family\" TEXT NOT NULL DEFAULT 'Mona', \"is_default\" INTEGER NOT NULL DEFAULT 0 CHECK (\"is_default\" IN (0, 1)), \"created_at\" INTEGER NULL, \"updated_at\" INTEGER NULL, \"deleted_at\" INTEGER NULL, \"org_id\" TEXT NULL, PRIMARY KEY (\"id\"));"
        }
      ]
    },
    {
      "name": "profiles",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"profiles\" (\"id\" TEXT NOT NULL, \"name\" TEXT NOT NULL, \"business_name\" TEXT NOT NULL DEFAULT '', \"logo\" BLOB NULL, \"logo_mime\" TEXT NULL, \"email\" TEXT NULL, \"phone\" TEXT NULL, \"website\" TEXT NULL, \"address\" TEXT NULL, \"abn\" TEXT NULL, \"payee_name\" TEXT NULL, \"bank_name\" TEXT NULL, \"bank_bsb\" TEXT NULL, \"bank_account\" TEXT NULL, \"swift\" TEXT NULL, \"payment_link\" TEXT NULL, \"currency\" TEXT NOT NULL DEFAULT 'USD', \"tax_label\" TEXT NULL, \"tax_rate\" REAL NULL, \"is_default\" INTEGER NOT NULL DEFAULT 0 CHECK (\"is_default\" IN (0, 1)), \"template_id\" TEXT NULL REFERENCES templates (id), \"region\" TEXT NOT NULL DEFAULT 'au', \"iban\" TEXT NULL, \"sort_code\" TEXT NULL, \"routing_number\" TEXT NULL, \"payid\" TEXT NULL, \"institution_number\" TEXT NULL, \"transit_number\" TEXT NULL, \"show_bank\" INTEGER NOT NULL DEFAULT 1 CHECK (\"show_bank\" IN (0, 1)), \"show_payment_link\" INTEGER NOT NULL DEFAULT 1 CHECK (\"show_payment_link\" IN (0, 1)), \"show_tax\" INTEGER NOT NULL DEFAULT 1 CHECK (\"show_tax\" IN (0, 1)), \"show_rate_column\" INTEGER NOT NULL DEFAULT 1 CHECK (\"show_rate_column\" IN (0, 1)), \"show_time_column\" INTEGER NOT NULL DEFAULT 1 CHECK (\"show_time_column\" IN (0, 1)), \"reverse_charge\" INTEGER NOT NULL DEFAULT 0 CHECK (\"reverse_charge\" IN (0, 1)), \"created_at\" INTEGER NULL, \"updated_at\" INTEGER NULL, \"deleted_at\" INTEGER NULL, \"org_id\" TEXT NULL, PRIMARY KEY (\"id\"));"
        }
      ]
    },
    {
      "name": "app_settings",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"app_settings\" (\"key\" TEXT NOT NULL, \"value\" TEXT NOT NULL, \"updated_at\" INTEGER NULL, PRIMARY KEY (\"key\"));"
        }
      ]
    },
    {
      "name": "active_timers",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"active_timers\" (\"id\" TEXT NOT NULL, \"project_id\" TEXT NULL REFERENCES projects (id), \"task_id\" TEXT NULL REFERENCES tasks (id), \"description\" TEXT NULL, \"started_at\" INTEGER NULL, \"accumulated_seconds\" INTEGER NOT NULL DEFAULT 0, \"running_since\" INTEGER NULL, \"created_at\" INTEGER NULL, \"updated_at\" INTEGER NULL, \"deleted_at\" INTEGER NULL, PRIMARY KEY (\"id\"));"
        }
      ]
    },
    {
      "name": "sync_outbox",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"sync_outbox\" (\"target_table\" TEXT NOT NULL, \"row_id\" TEXT NOT NULL, \"queued_at\" INTEGER NOT NULL, PRIMARY KEY (\"target_table\", \"row_id\"));"
        }
      ]
    }
