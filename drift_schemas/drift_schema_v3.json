  "fixed_sql": [
    {
      "name": "clients",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"clients\" (\"id\" INTEGER NOT NULL PRIMARY KEY AUTOINCREMENT, \"name\" TEXT NOT NULL, \"email\" TEXT NULL, \"address\" TEXT NULL, \"abn\" TEXT NULL, \"default_rate\" REAL NULL, \"archived_at\" INTEGER NULL);"
        }
      ]
    },
    {
      "name": "jobs",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"jobs\" (\"id\" INTEGER NOT NULL PRIMARY KEY AUTOINCREMENT, \"client_id\" INTEGER NOT NULL REFERENCES clients (id), \"code\" TEXT NOT NULL UNIQUE, \"title\" TEXT NOT NULL, \"rate\" REAL NULL, \"status\" TEXT NOT NULL DEFAULT 'active', \"created_at\" INTEGER NOT NULL DEFAULT (CAST(strftime('%s', CURRENT_TIMESTAMP) AS INTEGER)));"
        }
      ]
    },
    {
      "name": "tasks",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"tasks\" (\"id\" INTEGER NOT NULL PRIMARY KEY AUTOINCREMENT, \"job_id\" INTEGER NOT NULL REFERENCES jobs (id), \"title\" TEXT NOT NULL, \"rate\" REAL NULL, \"status\" TEXT NOT NULL DEFAULT 'active', \"created_at\" INTEGER NOT NULL DEFAULT (CAST(strftime('%s', CURRENT_TIMESTAMP) AS INTEGER)));"
        }
      ]
    },
    {
      "name": "time_entries",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"time_entries\" (\"id\" INTEGER NOT NULL PRIMARY KEY AUTOINCREMENT, \"job_id\" INTEGER NOT NULL REFERENCES jobs (id), \"task_id\" INTEGER NULL REFERENCES tasks (id), \"description\" TEXT NULL, \"started_at\" INTEGER NOT NULL, \"ended_at\" INTEGER NOT NULL, \"seconds\" INTEGER NOT NULL);"
        }
      ]
    }
  ]
